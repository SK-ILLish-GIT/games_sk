# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── PostgreSQL (auth + leaderboard) ─────────────────────────────
POSTGRES_USER=gamesadmin
POSTGRES_PASSWORD=gamespassword
POSTGRES_DB=gamesplatform
POSTGRES_PORT=5432
DATABASE_URL=postgresql://gamesadmin:gamespassword@postgres:5432/gamesplatform

# ─── MongoDB (game states) ────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=gamesadmin
MONGO_INITDB_ROOT_PASSWORD=gamespassword
MONGO_DB=games
MONGO_PORT=27017
MONGO_URL=mongodb://gamesadmin:gamespassword@mongo:27017/games?authSource=admin

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# ─── Service ports (exposed to Docker network only) ───────────────
AUTH_SERVICE_PORT=3001
LEADERBOARD_SERVICE_PORT=3002
TIC_TAC_TOE_SERVICE_PORT=3003
GUESS_NUMBER_SERVICE_PORT=3004

# ─── Gateway (public-facing) ──────────────────────────────────────
GATEWAY_PORT=3000
