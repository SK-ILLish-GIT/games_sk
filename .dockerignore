# Root-level .dockerignore — keeps the build context small now that services
# build with the repo root as context (so they can COPY packages/observability).

**/node_modules
**/dist
**/.git
**/coverage
**/.nyc_output

# Local data dirs / secrets
postgres_data/
mongo_data/
redis_data/
.env
*.log

# Editor / OS noise
.DS_Store
.idea/
.vscode/
.cursor/

# Frontend build output and large dirs
frontend/dist
frontend/.vite

# IMPORTANT: do NOT ignore packages/observability/dist — services need it.
!packages/observability/dist
!packages/observability/dist/**
