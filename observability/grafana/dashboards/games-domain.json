{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Overview",     "type": "dashboards", "tags": ["overview"] },
    { "title": "Auth",         "type": "dashboards", "tags": ["auth"] },
    { "title": "Hangman",      "type": "dashboards", "tags": ["hangman"] },
    { "title": "Guess Number", "type": "dashboards", "tags": ["guess-number"] },
    { "title": "Tic-Tac-Toe",  "type": "dashboards", "tags": ["tic-tac-toe"] }
  ],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "Activity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Games started (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "targets": [
        { "expr": "sum(increase(games_started_total[1h]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Games finished (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "targets": [
        { "expr": "sum(increase(games_finished_total[1h]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Overall win rate (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "targets": [
        { "expr": "100 * sum(increase(games_finished_total{outcome=\"won\"}[1h])) / clamp_min(sum(increase(games_finished_total[1h])), 1)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",    "value": null },
            { "color": "yellow", "value": 30 },
            { "color": "green",  "value": 60 }
          ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "type": "stat",
      "title": "Score-submit success (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "targets": [
        { "expr": "100 * sum(rate(leaderboard_score_submitted_total[5m])) / clamp_min(sum(rate(games_finished_total[5m])), 0.001)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",    "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "green",  "value": 95 }
          ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "type": "timeseries",
      "title": "Games started by game (per second)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "targets": [
        { "expr": "sum by (game) (rate(games_started_total[$__rate_interval]))", "legendFormat": "{{game}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "type": "timeseries",
      "title": "Games finished by outcome (per second)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "targets": [
        { "expr": "sum by (outcome) (rate(games_finished_total[$__rate_interval]))", "legendFormat": "{{outcome}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },

    {
      "type": "row",
      "title": "Outcomes & difficulty",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 101,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "barchart",
      "title": "Win rate by game (last 1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 7,
      "targets": [
        {
          "expr": "100 * sum by (game) (increase(games_finished_total{outcome=\"won\"}[1h])) / clamp_min(sum by (game) (increase(games_finished_total[1h])), 1)",
          "legendFormat": "{{game}}", "refId": "A", "instant": true, "format": "table"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "min": 0, "max": 100 } },
      "options": { "xField": "game", "orientation": "horizontal", "showValue": "always", "legend": { "showLegend": false } }
    },
    {
      "type": "barchart",
      "title": "Hangman win rate by difficulty (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 8,
      "targets": [
        {
          "expr": "100 * sum by (difficulty) (increase(games_finished_total{game=\"hangman\",outcome=\"won\"}[1h])) / clamp_min(sum by (difficulty) (increase(games_finished_total{game=\"hangman\"}[1h])), 1)",
          "legendFormat": "{{difficulty}}", "refId": "A", "instant": true, "format": "table"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "min": 0, "max": 100 } },
      "options": { "xField": "difficulty", "orientation": "horizontal", "showValue": "always", "legend": { "showLegend": false } }
    },
    {
      "type": "timeseries",
      "title": "Game duration p95 by game (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 9,
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, game) (rate(games_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "{{game}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "type": "heatmap",
      "title": "Score distribution (all games)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 10,
      "targets": [
        { "expr": "sum by (le) (increase(games_score_bucket[$__rate_interval]))", "format": "heatmap", "legendFormat": "{{le}}", "refId": "A" }
      ],
      "options": {
        "calculate": false,
        "yAxis": { "axisPlacement": "left", "unit": "none", "decimals": 0 },
        "color": { "scheme": "Spectral", "exponent": 0.5, "mode": "scheme", "steps": 64 },
        "cellGap": 1
      }
    },

    {
      "type": "row",
      "title": "Hangman: guess behaviour",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 102,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Hangman guesses per second by kind & correctness",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 11,
      "targets": [
        { "expr": "sum by (kind, correct) (rate(hangman_guesses_total[$__rate_interval]))", "legendFormat": "{{kind}} / {{correct}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } }
    },
    {
      "type": "stat",
      "title": "Hangman accuracy (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 32 },
      "id": 12,
      "targets": [
        { "expr": "100 * sum(rate(hangman_guesses_total{correct=\"true\"}[5m])) / clamp_min(sum(rate(hangman_guesses_total[5m])), 0.001)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",    "value": null },
            { "color": "yellow", "value": 30 },
            { "color": "green",  "value": 50 }
          ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "background" }
    },
    {
      "type": "barchart",
      "title": "Letter vs word guesses by difficulty (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 32 },
      "id": 13,
      "targets": [
        {
          "expr": "sum by (difficulty, kind) (increase(hangman_guesses_total[1h]))",
          "legendFormat": "{{difficulty}} / {{kind}}", "refId": "A", "instant": true, "format": "table"
        }
      ],
      "options": { "orientation": "horizontal", "showValue": "always", "legend": { "showLegend": true, "placement": "bottom" } }
    },

    {
      "type": "row",
      "title": "Leaderboard",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 103,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Score submissions to leaderboard by game",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 14,
      "targets": [
        { "expr": "sum by (game) (rate(leaderboard_score_submitted_total[$__rate_interval]))", "legendFormat": "{{game}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "type": "timeseries",
      "title": "Leaderboard reads by scope",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 15,
      "targets": [
        { "expr": "sum by (scope) (rate(leaderboard_lookups_total[$__rate_interval]))", "legendFormat": "{{scope}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },

    {
      "type": "row",
      "title": "Logs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "id": 104,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "logs",
      "title": "Game-service warnings & errors",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 50 },
      "id": 16,
      "targets": [
        { "expr": "{service=~\"hangman-service|guess-number-service|tic-tac-toe-service|leaderboard-service\"} |~ \"\\\"level\\\"\\\\s*:\\\\s*\\\"(error|warn)\\\"\"", "refId": "A" }
      ],
      "options": {
        "showTime": true, "showLabels": false, "wrapLogMessage": true,
        "dedupStrategy": "none", "enableLogDetails": true, "sortOrder": "Descending"
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["games", "domain"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Games Platform — Games",
  "uid": "games-domain",
  "version": 1,
  "weekStart": ""
}
