{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Auth Service", "type": "dashboards", "tags": ["auth"] },
    { "title": "Games",        "type": "dashboards", "tags": ["games"] }
  ],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "Service health (RED)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Services up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 10,
      "targets": [
        { "expr": "count(count by (service) (rate(traces_spanmetrics_calls_total[5m])))", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "green", "value": 3 }
          ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "type": "stat",
      "title": "Total req/s (last 5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 11,
      "targets": [
        { "expr": "sum(rate(traces_spanmetrics_calls_total[5m]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Error rate (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 12,
      "targets": [
        { "expr": "100 * sum(rate(traces_spanmetrics_calls_total{status_code=\"STATUS_CODE_ERROR\"}[5m])) / clamp_min(sum(rate(traces_spanmetrics_calls_total[5m])), 0.001)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red",    "value": 5 }
          ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "type": "stat",
      "title": "p95 latency (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 13,
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_latency_bucket[5m])))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "type": "stat",
      "title": "Active auth sessions",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 14,
      "targets": [
        { "expr": "max(auth_active_sessions)", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "type": "stat",
      "title": "Games finished (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 15,
      "targets": [
        { "expr": "sum(increase(games_finished_total[1h]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },

    {
      "type": "timeseries",
      "title": "Request rate by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 1,
      "targets": [
        { "expr": "sum by (service) (rate(traces_spanmetrics_calls_total[$__rate_interval]))", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } }
    },
    {
      "type": "timeseries",
      "title": "Error rate (%) by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 2,
      "targets": [
        {
          "expr": "100 * (sum by (service) (rate(traces_spanmetrics_calls_total{status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / clamp_min(sum by (service) (rate(traces_spanmetrics_calls_total[$__rate_interval])), 0.001))",
          "legendFormat": "{{service}}", "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red",    "value": 5 }
          ] }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["max"] } }
    },
    {
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 by service (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "id": 3,
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le, service) (rate(traces_spanmetrics_latency_bucket[$__rate_interval])))", "legendFormat": "p50 — {{service}}", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le, service) (rate(traces_spanmetrics_latency_bucket[$__rate_interval])))", "legendFormat": "p95 — {{service}}", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le, service) (rate(traces_spanmetrics_latency_bucket[$__rate_interval])))", "legendFormat": "p99 — {{service}}", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },

    {
      "type": "row",
      "title": "Container metrics",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 101,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Container CPU utilization (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "id": 5,
      "targets": [
        { "expr": "sum by (compose_service) (container_cpu_utilization_ratio)", "legendFormat": "{{compose_service}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } }
    },
    {
      "type": "timeseries",
      "title": "Container memory usage (bytes)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "id": 6,
      "targets": [
        { "expr": "sum by (compose_service) (container_memory_usage_total_bytes)", "legendFormat": "{{compose_service}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } }
    },

    {
      "type": "row",
      "title": "Logs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 102,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "logs",
      "title": "Recent error & warn logs (all services)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 31 },
      "id": 7,
      "targets": [
        { "expr": "{project=\"games_sk\"} |~ \"\\\"level\\\"\\\\s*:\\\\s*\\\"(error|warn)\\\"\"", "refId": "A" }
      ],
      "options": {
        "showTime": true, "showLabels": false, "wrapLogMessage": true,
        "dedupStrategy": "none", "enableLogDetails": true, "sortOrder": "Descending"
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["games", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Games Platform — Overview",
  "uid": "games-overview",
  "version": 2,
  "weekStart": ""
}
