{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Overview",         "type": "dashboards", "tags": ["overview"] },
    { "title": "Games (combined)", "type": "dashboards", "tags": ["domain"] },
    { "title": "Hangman",          "type": "dashboards", "tags": ["hangman"] },
    { "title": "Tic-Tac-Toe",      "type": "dashboards", "tags": ["tic-tac-toe"] }
  ],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "Activity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100, "collapsed": false, "panels": []
    },
    {
      "type": "stat",
      "title": "Started (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 }, "id": 1,
      "targets": [{ "expr": "sum(increase(games_started_total{game=\"guess-number\"}[1h]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Finished (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 }, "id": 2,
      "targets": [{ "expr": "sum(increase(games_finished_total{game=\"guess-number\"}[1h]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Win rate (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 }, "id": 3,
      "targets": [{ "expr": "100 * sum(increase(games_finished_total{game=\"guess-number\",outcome=\"won\"}[1h])) / clamp_min(sum(increase(games_finished_total{game=\"guess-number\"}[1h])), 1)", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "yellow", "value": 30 }, { "color": "green", "value": 60 }
          ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "type": "stat",
      "title": "Median duration",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 }, "id": 4,
      "targets": [{ "expr": "histogram_quantile(0.50, sum by (le) (rate(games_duration_seconds_bucket{game=\"guess-number\"}[$__rate_interval])))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 1 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "type": "stat",
      "title": "Avg score (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 1 }, "id": 5,
      "targets": [{ "expr": "sum(increase(games_score_sum{game=\"guess-number\"}[1h])) / clamp_min(sum(increase(games_score_count{game=\"guess-number\"}[1h])), 1)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "type": "stat",
      "title": "Score submissions (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 }, "id": 6,
      "targets": [{ "expr": "sum(increase(leaderboard_score_submitted_total{game=\"guess-number\"}[1h]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },

    {
      "type": "timeseries",
      "title": "Games per second",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }, "id": 7,
      "targets": [
        { "expr": "sum(rate(games_started_total{game=\"guess-number\"}[$__rate_interval]))",  "legendFormat": "started",  "refId": "A" },
        { "expr": "sum(rate(games_finished_total{game=\"guess-number\"}[$__rate_interval]))", "legendFormat": "finished", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Outcomes per second",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }, "id": 8,
      "targets": [
        { "expr": "sum by (outcome) (rate(games_finished_total{game=\"guess-number\"}[$__rate_interval]))", "legendFormat": "{{outcome}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },

    {
      "type": "heatmap",
      "title": "Score distribution",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 }, "id": 9,
      "targets": [
        { "expr": "sum by (le) (increase(games_score_bucket{game=\"guess-number\"}[$__rate_interval]))", "format": "heatmap", "legendFormat": "{{le}}", "refId": "A" }
      ],
      "options": {
        "calculate": false,
        "yAxis": { "axisPlacement": "left", "unit": "none", "decimals": 0 },
        "color": { "scheme": "Spectral", "exponent": 0.5, "mode": "scheme", "steps": 64 },
        "cellGap": 1
      }
    },
    {
      "type": "timeseries",
      "title": "Duration p50 / p95 (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 }, "id": 10,
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(games_duration_seconds_bucket{game=\"guess-number\"}[$__rate_interval])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(games_duration_seconds_bucket{game=\"guess-number\"}[$__rate_interval])))", "legendFormat": "p95", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },

    {
      "type": "row",
      "title": "Logs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 101, "collapsed": false, "panels": []
    },
    {
      "type": "logs",
      "title": "guess-number-service warnings & errors",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 23 }, "id": 11,
      "targets": [
        { "expr": "{service=\"guess-number-service\"} |~ \"\\\"level\\\"\\\\s*:\\\\s*\\\"(error|warn)\\\"\"", "refId": "A" }
      ],
      "options": {
        "showTime": true, "showLabels": false, "wrapLogMessage": true,
        "dedupStrategy": "none", "enableLogDetails": true, "sortOrder": "Descending"
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["games", "guess-number"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Games Platform — Guess Number",
  "uid": "games-guess-number",
  "version": 1,
  "weekStart": ""
}
