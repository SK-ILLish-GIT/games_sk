# EditorConfig — universal editor defaults so the basics agree before
# Prettier even runs. Most modern editors honour this out of the box.
# https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
# Don't strip trailing spaces in markdown — they can be intentional line breaks.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2
